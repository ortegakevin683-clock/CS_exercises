<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Anagrafica 5.0</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            max-width: 580px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 1.8em;
            font-size: 1.9rem;
        }

        .form-group {
            margin-bottom: 1.4em;
        }

        label {
            display: block;
            margin-bottom: 0.5em;
            font-weight: 500;
            color: #444;
        }

        input[type="text"],
        input[type="date"],
        select {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 1rem;
            box-sizing: border-box;
        }

        select[multiple] {
            height: 140px;
            padding: 8px;
        }

        .radio-group, .checkbox-group {
            margin-top: 0.4em;
        }

        .radio-group label,
        .checkbox-group label {
            display: inline-block;
            margin-right: 1.2em;
            font-weight: normal;
        }

        button {
            background-color: #34495e;
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 6px;
            font-size: 1.05rem;
            cursor: pointer;
            margin: 1.5em 0;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }

        button:hover {
            background-color: #2c3e50;
        }

        a {
            display: block;
            text-align: center;
            color: #555;
            text-decoration: none;
            margin-top: 1em;
        }

        a:hover {
            color: #2c3e50;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <h2>Anagrafica Utente</h2>

    <div class="form-group">
        <label for="nome">Nome</label>
        <input type="text" id="nome">
    </div>

    <div class="form-group">
        <label for="cognome">Cognome</label>
        <input type="text" id="cognome">
    </div>

    <div class="form-group">
        <label for="citta">Città</label>
        <input type="text" id="citta">
    </div>

    <div class="form-group">
        <label for="cap">CAP</label>
        <input type="text" id="cap">
    </div>

    <div class="form-group">
        <label for="dataNascita">Data di nascita</label>
        <input type="date" id="dataNascita">
    </div>

    <div class="form-group">
        <label>Sesso</label>
        <div class="radio-group">
            <label><input type="radio" name="sesso" value="Maschio" id="sessoM"> Maschio</label>
            <label><input type="radio" name="sesso" value="Femmina" id="sessoF"> Femmina</label>
            <label><input type="radio" name="sesso" value="Altro" id="sessoAltro"> Altro</label>
        </div>
    </div>

    <div class="form-group">
        <label>Mezzi posseduti</label>
        <div class="checkbox-group">
            <label><input type="checkbox" value="Auto" id="auto"> Auto</label>
            <label><input type="checkbox" value="Moto" id="moto"> Moto</label>
            <label><input type="checkbox" value="Bici" id="bici"> Bici</label>
            <label><input type="checkbox" value="Cavallo" id="cavallo"> Cavallo</label>
            <label><input type="checkbox" value="Deltaplano" id="deltaplano"> Deltaplano</label>
        </div>
    </div>

    <div class="form-group">
        <label for="provincia">Provincia</label>
        <select id="provincia">
            <option value="MI">Milano</option>
            <option value="VA">Varese</option>
            <option value="NA">Napoli</option>
            <option value="TO">Torino</option>
            <option value="FI">Firenze</option>
        </select>
    </div>

    <div class="form-group">
        <label for="materie">Materie preferite (CTRL+click per più scelte)</label>
        <select id="materie" multiple size="5">
            <option value="Italiano">Italiano</option>
            <option value="Storia">Storia</option>
            <option value="Matematica">Matematica</option>
            <option value="TPSIT">TPS</option>
            <option value="Inglese">Inglese</option>
        </select>
    </div>

    <button onclick="mostraRisultato()">Invia</button>

    <a href="stampaAnagrafica.html">Stampa</a>

    <script>
        let ele = JSON.parse(localStorage.getItem("elenco")) || [];

        function getGenerazione(anno) {
            if (anno >= 2013) return "Generazione Alpha";
            if (anno >= 1997) return "Generazione Z";
            if (anno >= 1981) return "Millennials";
            if (anno >= 1965) return "Generazione X";
            if (anno >= 1946) return "Baby Boomers";
            if (anno >= 1928) return "Generazione Silenziosa";
            if (anno >= 1901) return "Greatest Generation";
            return "Generazione non definita";
        }

        function mostraRisultato() {
            let persona = {
                nome: document.getElementById("nome").value.trim(),
                cognome: document.getElementById("cognome").value.trim(),
                citta: document.getElementById("citta").value.trim(),
                cap: document.getElementById("cap").value.trim(),
                dataNascita: document.getElementById("dataNascita").value,
                sesso: document.querySelector('input[name="sesso"]:checked')?.value || "N/D",
                mezzi: Array.from(document.querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.value),
                provincia: document.getElementById("provincia").value,
                materie: Array.from(document.getElementById("materie").selectedOptions).map(opt => opt.value)
            };

            let anno = new Date(persona.dataNascita).getFullYear();
            let oggi = new Date().getFullYear();
            persona.eta = oggi - anno;
            persona.generazione = getGenerazione(anno);

            ele.push(persona);
            localStorage.setItem("elenco", JSON.stringify(ele));

            // Opzionale: alert di conferma (puoi toglierlo se vuoi)
            // alert("Dati salvati!");
        }
    </script>

</body>
</html>
